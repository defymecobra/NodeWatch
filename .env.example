# NodeWatch - Environment Variables
# Copy this file to .env and fill in your values

# ── Database ─────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_USER=nodewatch
DB_PASSWORD=nodewatch_secret
DB_NAME=nodewatch_db

# ── Backend ──────────────────────────────────────
PORT=3000
NODE_ENV=development

# Secret for signing JWT tokens (change in production!)
JWT_SECRET=change_me_in_production_super_secret_key
JWT_EXPIRES_IN=7d

# ── Telegram Alerts ──────────────────────────────
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
