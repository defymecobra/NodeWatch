# ╔══════════════════════════════════════════════════════════════╗
# ║              NodeWatch - Environment Variables              ║
# ║     Copy this file to .env and fill in your values          ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Database ─────────────────────────────────────
DB_HOST=db                          # Use 'db' for Docker, 'localhost' for local dev
DB_PORT=5432
DB_USER=nodewatch
DB_PASSWORD=nodewatch_secret
DB_NAME=nodewatch_db

# ── Backend ──────────────────────────────────────
PORT=3000
NODE_ENV=development                # 'development' or 'production'

# Secret for signing JWT tokens (CHANGE IN PRODUCTION!)
JWT_SECRET=change_me_in_production_super_secret_key
JWT_EXPIRES_IN=7d

# ── Telegram Alerts ──────────────────────────────
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Frontend (Vite) ─────────────────────────────
# Only needed for local development (not Docker)
# VITE_API_URL=http://localhost:3000/api/v1
